<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 앱 전역 테마: 플랫폼에 존재하는 NoActionBar 테마를 부모로 사용 -->
    <style name="Theme.AlcoholicTimer" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <!-- 상태바를 시스템이 항상 표시하도록 보장 -->
        <item name="android:windowFullscreen">false</item>
        <!-- 상태바/내비게이션바 배경은 흰색 -->
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:navigationBarColor">@android:color/white</item>

        <!-- Splash와 동일한 배경을 유지하여 전환 시 깜빡임 제거 -->
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <!-- 일부 기기에서 상태바 아래 얇은 선(오버레이) 제거 -->
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- 스플래시 테마 (Android 11 이하용) -->
    <style name="Theme.AlcoholicTimer.Splash" parent="Theme.AlcoholicTimer">
        <!-- windowBackground를 스플래시 배경으로 사용 -->
        <item name="android:windowBackground">@drawable/splash_screen</item>

        <!-- 시스템 바 색상 -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#f28090</item>
        <item name="android:navigationBarColor">#f28090</item>
    </style>
</resources>
